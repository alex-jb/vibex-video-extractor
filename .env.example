# Shared secret between this sidecar and the vibex Vercel function.
# Generate with: openssl rand -base64 32
BEARER_TOKEN=replace-me-with-openssl-rand

# Optional: Netscape-format cookies.txt exported from a logged-in browser
# session on douyin.com. yt-dlp Douyin extractor often requires this.
# In Railway, add as a "Volume" → mount path /app/cookies.txt
COOKIES_FILE=/app/cookies.txt

# Max video file size in MB (default 100). Hard-rejects larger downloads.
MAX_FILESIZE_MB=100

# Override tmp dir if your Railway plan has restrictive /tmp.
TMP_DIR=/tmp/extractor
